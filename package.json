{
  "name": "multimodal-mcp",
  "version": "1.0.0",
  "description": "Multi-provider media generation MCP server",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "multimodal-mcp": "build/index.js"
  },
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "media",
    "image-generation",
    "video-generation",
    "audio-generation",
    "text-to-speech",
    "openai",
    "xai",
    "google",
    "claude"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "openai": "^6.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
